nextflow_process {

    name "Test FASTQC process"
    script "../modules/fastqc.nf"
    process "FASTQC"

    test("Run FASTQC on small FASTQ") {

        input:
        path "tests/data/sample.fastq.gz"

        when:
        process.run()

        then:
        assert process.success
        assert process.out.size() == 2

        assert file(process.out[0]).name.endsWith(".html")
        assert file(process.out[1]).name.endsWith(".zip")
    }
}